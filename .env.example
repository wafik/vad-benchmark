# ── Audio ─────────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# ── Whisper / STT engine ─────────────────────────────────────
# whisper-cli binary. May be:
#   - a bare name on PATH:                       whisper-cli
#   - an absolute path:                          /home/me/whisper.cpp/build/bin/whisper-cli
#   - any shell command (Windows + Jetson!):     ssh jetson-nano-ssh 'whisper.cpp/build/bin/whisper-cli'
WHISPER_CLI_CMD=whisper-cli

# Whisper model (must be in models/)
WHISPER_MODEL=ggml-tiny.id.bin
LANGUAGE=id
THREADS=4

# ── Silero VAD ────────────────────────────────────────────────
# VAD_ENABLED remains supported for legacy .env files (true=builtin, false=off).
# VAD_MODE: off | builtin | presegmented | rms_energy
VAD_MODE=builtin
VAD_MODEL_PATH=ggml-silero-v6.2.0.bin
VAD_THRESHOLD=0.5
VAD_MIN_SPEECH_MS=250
VAD_MIN_SILENCE_MS=100
VAD_SPEECH_PAD_MS=30
VAD_MAX_SPEECH_S=0

# ── RMS-energy VAD (rms_energy mode; pure Python, no model file) ──
# Fraction of the file's peak RMS a frame must reach to count as speech.
RMS_THRESHOLD=0.05

# ── Server ────────────────────────────────────────────────────
SERVE_HOST=127.0.0.1
SERVE_PORT=8770

# HTTP Basic Auth password gating the whole dashboard (any username works).
# Mirrors the sibling ocr-benchmark project. The browser pops a native
# login prompt on first visit. Override this in production.
AUTH_PASSWORD=AI4DB-BENCH

# ── Misc ──────────────────────────────────────────────────────
# Path to ffmpeg if it's not on PATH (e.g. Gyan.FFmpeg portable install).
# Leave empty to auto-resolve.
# FFMPEG_BIN=C:\Users\Ulinn\AppData\Local\Microsoft\WinGet\Packages\Gyan.FFmpeg_Microsoft.Winget.Source_8wekyb3d8bbwe\ffmpeg-8.1.2-full_build\bin\ffmpeg.exe
